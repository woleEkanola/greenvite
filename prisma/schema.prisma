generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      Role     @default(ADMIN)
  email     String?  @unique
  name      String?
  phone     String?  @unique
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id          String       @id @default(cuid())
  name        String
  capacity    Int
  color       String       @default("#000000")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  accessCodes AccessCode[]
  hosts       Host[]       @relation("HostToTable")
  souvenirs   SouvenirAssignment[]
}

model AccessCode {
  id         String    @id @default(cuid())
  code       String    @unique
  rsvpId     String
  type       String
  name       String
  isAdmitted Boolean   @default(false)
  admittedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  isSent     Boolean   @default(false)
  sentAt     DateTime?
  tableId    String?
  rsvp       Rsvp      @relation(fields: [rsvpId], references: [id])
  table      Table?    @relation(fields: [tableId], references: [id])
  souvenirs  SouvenirAssignment[]
}

model Rsvp {
  id               String           @id @default(cuid())
  name             String
  email            String
  hasGuest         Boolean          @default(false)
  hasDriver        Boolean          @default(false)
  hasAide          Boolean          @default(false)
  codeId           String           @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  phone            String?
  accessCodes      AccessCode[]
  registrationCode RegistrationCode @relation(fields: [codeId], references: [id])
}

model RegistrationCode {
  id        String    @id @default(cuid())
  code      String    @unique
  used      Boolean   @default(false)
  usedAt    DateTime?
  status    String    @default("available")
  createdAt DateTime  @default(now())
  invite    Invite?
  rsvp      Rsvp?
}

model Invite {
  id                 String            @id @default(cuid())
  name               String
  email              String?
  phone              String?
  sent               Boolean           @default(true)
  sentAt             DateTime          @default(now())
  type               String
  status             String
  emailStatus        String?
  smsStatus          String?
  smsProvider        String?
  errorMessage       String?
  code               String?
  registrationCodeId String?           @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  whatsappStatus     String?
  whatsappProvider   String?
  batchId            String?
  Batch              Batch?            @relation(fields: [batchId], references: [id])
  registrationCode   RegistrationCode? @relation(fields: [registrationCodeId], references: [id])
}

model Batch {
  id            String   @id @default(cuid())
  name          String?
  status        String   @default("pending")
  totalInvites  Int      @default(0)
  sentInvites   Int      @default(0)
  failedInvites Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  invites       Invite[]
}

model Host {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  role        String   @default("host") // host or hostess
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tables      Table[]  @relation("HostToTable")
  souvenirs   SouvenirAssignment[]
}

model Souvenir {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  image       String?
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignments SouvenirAssignment[]
}

model SouvenirAssignment {
  id          String   @id @default(cuid())
  quantity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  hostId      String?
  host        Host?    @relation(fields: [hostId], references: [id])
  tableId     String?
  table       Table?   @relation(fields: [tableId], references: [id])
  accessCodeId String?
  accessCode  AccessCode? @relation(fields: [accessCodeId], references: [id])
  
  souvenirId  String
  souvenir    Souvenir @relation(fields: [souvenirId], references: [id])

  @@unique([souvenirId, hostId, tableId, accessCodeId])
}
