generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(cuid())
  username         String            @unique
  password         String
  role             String            @default("ADMIN")
  email            String?           @unique
  name             String?
  phone            String?           @unique
  verified         Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  ownedEvents      Event[]           @relation("EventOwner")
  adminEvents      EventAdmin[]
  sentInvitations  AdminInvitation[] @relation("UserToAdminInvitation")
}

model Table {
  id          String       @id @default(cuid())
  name        String
  capacity    Int
  color       String       @default("#000000")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  accessCodes AccessCode[]
  hosts       Host[]       @relation("HostToTable")
  souvenirs   SouvenirAssignment[]
  eventId     String?
  event       Event?       @relation(fields: [eventId], references: [id])
}

model AccessCode {
  id         String    @id @default(cuid())
  code       String    @unique
  rsvpId     String
  type       String
  name       String
  isAdmitted Boolean   @default(false)
  admittedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  isSent     Boolean   @default(false)
  sentAt     DateTime?
  tableId    String?
  rsvp       Rsvp      @relation(fields: [rsvpId], references: [id])
  table      Table?    @relation(fields: [tableId], references: [id])
  souvenirs  SouvenirAssignment[]
}

model Rsvp {
  id               String           @id @default(cuid())
  name             String
  email            String
  hasGuest         Boolean          @default(false)
  hasDriver        Boolean          @default(false)
  hasAide          Boolean          @default(false)
  codeId           String           @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  phone            String?
  accessCodes      AccessCode[]
  registrationCode RegistrationCode @relation(fields: [codeId], references: [id])
}

model RegistrationCode {
  id        String    @id @default(cuid())
  code      String    @unique
  used      Boolean   @default(false)
  usedAt    DateTime?
  status    String    @default("available")
  createdAt DateTime  @default(now())
  invite    Invite?
  rsvp      Rsvp?
  eventId   String?
  event     Event?    @relation(fields: [eventId], references: [id])
}

model Invite {
  id                 String            @id @default(cuid())
  name               String
  email              String?
  phone              String?
  sent               Boolean           @default(true)
  sentAt             DateTime          @default(now())
  type               String
  status             String
  emailStatus        String?
  smsStatus          String?
  smsProvider        String?
  errorMessage       String?
  code               String?
  registrationCodeId String?           @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  whatsappStatus     String?
  whatsappProvider   String?
  batchId            String?
  Batch              Batch?            @relation(fields: [batchId], references: [id])
  registrationCode   RegistrationCode? @relation(fields: [registrationCodeId], references: [id])
}

model Batch {
  id            String   @id @default(cuid())
  name          String?
  status        String   @default("pending")
  totalInvites  Int      @default(0)
  sentInvites   Int      @default(0)
  failedInvites Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  invites       Invite[]
  eventId       String?
  event         Event?   @relation(fields: [eventId], references: [id])
}

model Host {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  role        String   @default("host") // host or hostess
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tables      Table[]  @relation("HostToTable")
  souvenirs   SouvenirAssignment[]
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id])
}

model Souvenir {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  image       String?
  quantity    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignments SouvenirAssignment[]
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id])
}

model SouvenirAssignment {
  id          String   @id @default(cuid())
  quantity    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  hostId      String?
  host        Host?    @relation(fields: [hostId], references: [id])
  tableId     String?
  table       Table?   @relation(fields: [tableId], references: [id])
  accessCodeId String?
  accessCode  AccessCode? @relation(fields: [accessCodeId], references: [id])
  
  souvenirId  String
  souvenir    Souvenir @relation(fields: [souvenirId], references: [id])

  @@unique([souvenirId, hostId, tableId, accessCodeId])
}

model Event {
  id                String        @id @default(cuid())
  title             String
  description       String?       @db.Text
  location          String?
  startDate         DateTime
  endDate           DateTime
  imageUrl          String?
  status            String        @default("draft") // draft, published, cancelled
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  slug              String?       @unique
  ownerId           String        // Original creator of the event
  owner             User          @relation("EventOwner", fields: [ownerId], references: [id])
  admins            EventAdmin[]  // Many-to-many relation with User
  adminInvitations  AdminInvitation[]
  tables            Table[]
  registrationCodes RegistrationCode[]
  batches           Batch[]
  hosts             Host[]
  souvenirs         Souvenir[]
  messageTemplates  MessageTemplate[]
}

model EventAdmin {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  event     Event    @relation(fields: [eventId], references: [id])

  @@unique([userId, eventId])
}

model AdminInvitation {
  id          String    @id @default(cuid())
  email       String
  token       String    @unique
  status      String    @default("pending") // pending, accepted, expired
  message     String?   @db.Text
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  acceptedAt  DateTime?
  
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id])
  inviterId   String
  inviter     User      @relation("UserToAdminInvitation", fields: [inviterId], references: [id])
  
  @@unique([email, eventId])
}

model MessageTemplate {
  id              String    @id @default(cuid())
  name            String
  emailSubject    String
  emailContent    String    @db.Text
  whatsappContent String    @db.Text
  isDefault       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  eventId         String
  event           Event     @relation(fields: [eventId], references: [id])
  
  @@unique([name, eventId])
}
